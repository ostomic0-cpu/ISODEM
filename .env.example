# QMS App — Environment Configuration
# Copy this file to .env and update the values before starting the app.
#
#   Linux/WSL:  cp .env.example .env
#   Windows:    copy .env.example .env
#
# ⚠ CRITICAL: Change all passwords and secrets before deploying to production.

# Database connection string (SQLite)
# Default: local file in prisma/ directory
DATABASE_URL="file:./dev.db"

# JWT signing secret — used to sign session cookies
# Generate a secure random key:
#   Linux:  openssl rand -hex 32
#   Windows (PowerShell): [System.Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# ⚠ Change this before real use!
JWT_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"

# Node environment
# "production" for optimized serving, "development" for verbose logs
NODE_ENV="production"

# Server port (default: 3000)
# PORT=3000
