generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                        String            @id @default(cuid())
  email                     String            @unique
  passwordHash              String
  name                      String
  department                String
  roleId                    String
  role                      Role              @relation(fields: [roleId], references: [id])
  isActive                  Boolean           @default(true)
  documents                 Document[]
  approvedDocuments         Document[]        @relation("ApprovedDocuments")
  submittedDocumentVersions DocumentVersion[] @relation("SubmittedVersions")
  approvedDocumentVersions  DocumentVersion[] @relation("ApprovedVersions")
  audits                    Audit[]
  capas                     CAPA[]
  activityLogs              ActivityLog[]
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  description String?
  users       User[]
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  module    String
  action    String
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([module, action, roleId])
}

model Folder {
  id        String     @id @default(cuid())
  name      String
  parentId  String?
  parent    Folder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  Folder[]   @relation("FolderTree")
  documents Document[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Department {
  id        String       @id @default(cuid())
  name      String       @unique
  parentId  String?
  parent    Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentTree")
  audits    Audit[]
  capas     CAPA[]
  documents Document[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Document {
  id          String            @id @default(cuid())
  docNumber   String            @unique
  title       String
  category    String
  status      String
  ownerId     String
  owner       User              @relation(fields: [ownerId], references: [id])
  department  String
  departmentId String?
  departmentRel Department? @relation(fields: [departmentId], references: [id])
  folderId    String
  folder      Folder            @relation(fields: [folderId], references: [id])
  versions    DocumentVersion[]
  rejectReason String?
  approvalDate DateTime?
  approvedById String?
  approvedBy  User?             @relation("ApprovedDocuments", fields: [approvedById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model DocumentCounter {
  id           String   @id @default(cuid())
  category     String
  year         Int
  nextSequence Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([category, year])
}

model DocumentVersion {
  id               String    @id @default(cuid())
  versionNumber    String
  originalFilename String
  storedFilename   String
  filePath         String
  changeSummary    String
  status           String
  submittedById    String
  submittedBy      User      @relation("SubmittedVersions", fields: [submittedById], references: [id])
  approvedById     String?
  approvedBy       User?     @relation("ApprovedVersions", fields: [approvedById], references: [id])
  documentId       String
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Audit {
  id            String         @id @default(cuid())
  title         String
  scheduleDate  DateTime
  status        String
  auditorId     String
  auditor       User           @relation(fields: [auditorId], references: [id])
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  checklistData String
  findings      AuditFinding[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model AuditFinding {
  id          String   @id @default(cuid())
  type        String
  severity    String   @default("OBS")
  description String
  status      String
  auditId     String
  audit       Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
  capa        CAPA?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CAPA {
  id                String       @id @default(cuid())
  capaNumber        String?      @unique
  findingId         String       @unique
  finding           AuditFinding @relation(fields: [findingId], references: [id], onDelete: Cascade)
  rcaNotes          String
  actionPlan        String
  verificationNotes String?
  status            String
  assigneeId        String
  assignee          User         @relation(fields: [assigneeId], references: [id])
  departmentId      String?
  department        Department?  @relation(fields: [departmentId], references: [id])
  priority          String       @default("MEDIUM")
  targetDate        DateTime
  dueDate           DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model CapaCounter {
  id           String   @id @default(cuid())
  year         Int
  nextSequence Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([year])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  metadata  String   @default("{}")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
